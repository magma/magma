[Unit]
Description=Magma eBPF Python Manager
After=network.target magma-ebpf-loader.service
Wants=magma-ebpf-loader.service

[Service]
Type=simple
ExecStart=/usr/bin/python3 /opt/magma/ebpf/python/ebpf_manager.py
Restart=on-failure
RestartSec=5s
User=root
Group=root
WorkingDirectory=/opt/magma/ebpf/python
Environment="PYTHONUNBUFFERED=1"
# Optional: logging to journal
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
