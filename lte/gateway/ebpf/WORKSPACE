# WORKSPACE
# Root Bazel workspace for Magma eBPF project

workspace(name = "magma_ebpf")

# Load Bazel C/C++ rules
load("@bazel_tools//tools/build_defs/repo:http.bzl", "http_archive")

# Optional: Add external C/C++ dependencies if needed
# http_archive(
